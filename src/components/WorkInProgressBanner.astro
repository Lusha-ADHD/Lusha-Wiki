---
const messages = {
  en: {
    label: 'Work in progress',
    text: 'This wiki is under construction. Some pages may be incomplete or change soon.',
  },
  fr: {
    label: 'Wiki en cours de construction',
    text: 'Certaines pages peuvent être incomplètes ou évoluer prochainement.',
  },
  de: {
    label: 'Wiki im Aufbau',
    text: 'Einige Seiten können unvollständig sein oder sich bald ändern.',
  },
  it: {
    label: 'Wiki in costruzione',
    text: 'Alcune pagine potrebbero essere incomplete o cambiare presto.',
  },
  es: {
    label: 'Wiki en construcción',
    text: 'Algunas páginas pueden estar incompletas o cambiar pronto.',
  },
  'pt-br': {
    label: 'Wiki em construção',
    text: 'Algumas páginas podem estar incompletas ou mudar em breve.',
  },
} as const;

const routeLang = Astro.locals.starlightRoute.lang.toLowerCase();
const baseLang = routeLang.split('-')[0];
const message =
  messages[routeLang as keyof typeof messages] ??
  messages[baseLang as keyof typeof messages] ??
  messages.en;
const { banner } = Astro.locals.starlightRoute.entry.data;
---

<div class="lusha-wip-banner" role="status" data-pagefind-ignore>
  <strong>{message.label}</strong>
  <span>{message.text}</span>
</div>

{banner && <div class="sl-banner" data-pagefind-ignore set:html={banner.content} />}

<style>
  @layer starlight.core {
    .lusha-wip-banner {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.35rem 0.65rem;
      padding: 0.75rem var(--sl-nav-pad-x);
      border-bottom: 1px solid rgb(138 90 43 / 24%);
      background: linear-gradient(180deg, #fff4e1, #ffe3bd);
      color: var(--lusha-blue-night);
      font-size: var(--sl-text-sm);
      line-height: 1.4;
      text-align: center;
      text-wrap: balance;
      box-shadow: var(--sl-shadow-sm);
    }

    .lusha-wip-banner strong {
      color: #063f2c;
      font-weight: 800;
    }

    :root[data-theme='dark'] .lusha-wip-banner {
      border-bottom-color: rgb(214 242 166 / 20%);
      background: linear-gradient(180deg, #263a22, #172a22);
      color: var(--sl-color-gray-1);
    }

    :root[data-theme='dark'] .lusha-wip-banner strong {
      color: var(--sl-color-accent-high);
    }

    .sl-banner {
      --__sl-banner-text: var(--sl-color-banner-text, var(--sl-color-text-invert));
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      background-color: var(--sl-color-banner-bg, var(--sl-color-bg-accent));
      color: var(--__sl-banner-text);
      line-height: var(--sl-line-height-headings);
      text-align: center;
      text-wrap: balance;
      box-shadow: var(--sl-shadow-sm);
    }

    .sl-banner :global(a) {
      color: var(--__sl-banner-text);
    }
  }
</style>
