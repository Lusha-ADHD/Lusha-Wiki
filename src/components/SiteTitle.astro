---
import lushaLogo from '../assets/Logo_Lusha.png';

const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title lusha-site-title sl-flex" aria-label="Lusha Wiki">
  <img src={lushaLogo.src} alt="Lusha" width={lushaLogo.width} height={lushaLogo.height} />
  <span translate="no">Wiki</span>
</a>

<style>
  @layer starlight.core {
    .lusha-site-title {
      align-items: center;
      gap: 0.45rem;
      font-size: var(--sl-text-h4);
      font-weight: 800;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }

    .lusha-site-title img {
      height: calc((var(--sl-nav-height) - 1.1rem) * 1.25);
      width: auto;
      object-fit: contain;
    }

    .lusha-site-title span {
      overflow: hidden;
    }
  }
</style>
